<header>
  <!-- Nav Bar -->
  <nav
    id="navbar"
    class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}"
    role="navigation"
  >
    <div class="container">
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          <!-- Home -->
          <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/' | relative_url }}">
              Home
              {% if page.permalink == '/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- People -->
          <li class="nav-item {% if page.permalink == '/people/' or page.url contains '/people/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/people/' | relative_url }}">
              People
              {% if page.permalink == '/people/' or page.url contains '/people/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Research -->
          <li class="nav-item {% if page.permalink == '/projects/' or page.url contains '/projects/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/projects/' | relative_url }}">
              Research
              {% if page.permalink == '/projects/' or page.url contains '/projects/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Publications -->
          <li class="nav-item {% if page.permalink == '/publications/' or page.url contains '/publications/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/publications/' | relative_url }}">
              Publications
              {% if page.permalink == '/publications/' or page.url contains '/publications/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

<!-- Contact -->
<li class="nav-item {% if page.permalink == '/contact/' or page.url contains '/contact/' %}active{% endif %}">
  <a class="nav-link" href="{{ '/contact/' | relative_url }}">
    Contact
    {% if page.permalink == '/contact/' or page.url contains '/contact/' %}
      <span class="sr-only">(current)</span>
    {% endif %}
  </a>
</li>
        </ul>
      </div>
    </div>
  </nav>



  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
